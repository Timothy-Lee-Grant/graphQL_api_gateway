# GraphQL Gateway — Environment Variables
# Copy this file to .env and fill in your API keys

# NewsAPI.org — free tier: 100 req/day
# Get your key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage — free tier: 25 req/day
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# Open-Meteo (weather) — completely free, no key needed
